#!/usr/bin/env bash
# Stub `gh` for commitcraft tests — makes release-please history deterministic
# and offline. Controlled by env:
#   STUB_GH_AUTHED=1|0    -> `gh auth status` exit code (default authed)
#   STUB_GH_LABELS="..."  -> newline list `gh label list` prints (default none)
case "${1:-} ${2:-}" in
    "auth status") [ "${STUB_GH_AUTHED:-1}" = "1" ] && exit 0 || exit 1 ;;
    "label list")  [ -n "${STUB_GH_LABELS:-}" ] && printf '%s\n' "$STUB_GH_LABELS" ; exit 0 ;;
    *) exit 0 ;;
esac
